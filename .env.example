GEMINI_API_KEY=REPLACE_WITH_YOUR_KEY
# OPTISCANN Environment Variables
# Get your API key from https://aistudio.google.com/app/apikey
GEMINI_API_KEY=YOUR_API_KEY_HERE

# Local development database (default)
DB_TYPE=sqlite
DATABASE_PATH=./optiscann.db

# Production database example (PostgreSQL / Supabase / Neon)
# DB_TYPE=postgresql
# DATABASE_URL=postgresql://user:password@host:5432/dbname

# Frontend API base URL for deployed frontend/backend split
# VITE_API_URL=https://your-backend-url.com
# VITE_API_BASE_URL=https://your-backend-url.com
